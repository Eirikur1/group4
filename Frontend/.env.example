# Copy this file to .env or .env.local and fill in your values.
# The app loads .env (Expo also loads .env.local). Do not commit .env or .env.local.

# Supabase (for Storage photo uploads from the app)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend API (water_sources read/write). Use your machine's IP (e.g. http://192.168.1.x:3000) when testing in Expo Go on a device.
EXPO_PUBLIC_API_URL=http://localhost:3000